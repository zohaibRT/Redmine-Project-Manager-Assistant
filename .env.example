# Copy to .env - do not commit .env

# LLM
# Keep real keys in .env only. Never commit API keys.
# Options: openai, local
LLM_PROVIDER=local

# Locally deployed / in-house OpenAI-compatible model
# If only SSH is available, create an SSH tunnel outside the app and point this to the tunnel.
# Example: ssh -L 8000:localhost:8000 dev@192.168.99.95
LOCAL_MODEL_BASE_URL=http://192.168.99.95:8000/v1
LOCAL_MODEL_NAME=Qwen/Qwen3-8B-AWQ
LOCAL_MODEL_API_KEY=EMPTY

# OpenAI GPT
# Use LLM_PROVIDER=openai to enable this.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.5


# Redmine (live - required)
REDMINE_URL=https://redmine.rolustech.com
REDMINE_API_KEY=your-redmine-api-key

# Optional: scope issue search to one project
# REDMINE_PROJECT_ID=18

# Optional: default project for new issues (name, identifier, or numeric id)
# Falls back to REDMINE_PROJECT_ID when unset
# REDMINE_DEFAULT_PROJECT_ID=1576

# Optional: default tracker id for new issues (some Redmine instances require it)
# When unset, the first tracker from /trackers.json is used automatically
# REDMINE_DEFAULT_TRACKER_ID=3

# Optional: required Redmine time-entry custom fields
# Only needed if /custom_fields.json is not visible to your API user.
# REDMINE_BILLABLE_HOURS_CUSTOM_FIELD_ID=30
# REDMINE_TIME_ENTRY_COMMENTS_CUSTOM_FIELD_ID=31

# Optional: LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
