# Copy to .env — do not commit .env

# LLM (Qwen via vLLM)
OPENAI_API_BASE=http://192.168.99.95:8000/v1
OPENAI_API_KEY=EMPTY
LOCAL_MODEL=Qwen/Qwen3-8B-AWQ
BASIC_AUTH_USERNAME=dev
BASIC_AUTH_PASSWORD=your-password-here

# Redmine (live — required)
REDMINE_URL=https://redmine.rolustech.com
REDMINE_API_KEY=your-redmine-api-key

# Optional: scope issue search to one project
# REDMINE_PROJECT_ID=18

# Optional: default project for new issues (name, identifier, or numeric id)
# Falls back to REDMINE_PROJECT_ID when unset
# REDMINE_DEFAULT_PROJECT_ID=1576

# Optional: default tracker id for new issues (some Redmine instances require it)
# When unset, the first tracker from /trackers.json is used automatically
# REDMINE_DEFAULT_TRACKER_ID=3

# Optional: LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
